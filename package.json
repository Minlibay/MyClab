{
  "name": "stream-titles",
  "version": "1.0.0",
  "description": "Real-time speech recognition and translation overlay for streamers",
  "main": "main.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "react:start": "cd ui && npm start",
    "dev": "concurrently \"npm run react:start\" \"wait-on http://localhost:3000 && npm start\"",
    "build": "cd ui && npm run build",
    "package": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "streaming",
    "overlay",
    "translation",
    "speech-recognition",
    "obs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "debug": "^4.4.3",
    "electron": "^41.2.0",
    "express": "^5.2.1",
    "wait-on": "^9.0.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.streamtitles.app",
    "productName": "StreamTitles",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "overlay/**/*",
      "ui/build/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
